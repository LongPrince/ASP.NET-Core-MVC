@model SV22T1020659.Models.Common.PagedResult<SV22T1020659.Models.Sales.OrderViewInfo>
@{
    ViewData["Title"] = "Lịch sử mua hàng";
}

<div class="card border-0 shadow-sm mb-5">
    <div class="card-header bg-white border-bottom-0 pt-4 pb-3">
        <h4 class="fw-bold"><i class="fa-solid fa-clock-rotate-left me-2 text-primary"></i>Lịch sử mua hàng</h4>
    </div>
    <div class="card-body p-0">
        @if (Model == null || Model.DataItems.Count == 0)
        {
            <div class="text-center py-5">
                <i class="fa-regular fa-folder-open text-muted mb-3" style="font-size: 3rem;"></i>
                <h5 class="text-muted">Bạn chưa có đơn hàng nào.</h5>
                <a href="~/Product" class="btn btn-primary mt-3">Mua sắm ngay</a>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Mã ĐH</th>
                            <th>Ngày đặt</th>
                            <th>Nơi giao</th>
                            <th>Trạng thái</th>
                            <th class="text-end pe-4">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">#@item.OrderID</td>
                                <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.DeliveryProvince</td>
                                <td>
                                    @{
                                        string bgClass = item.Status switch
                                        {
                                            SV22T1020659.Models.Sales.OrderStatusEnum.New => "bg-info text-dark",
                                            SV22T1020659.Models.Sales.OrderStatusEnum.Accepted => "bg-primary",
                                            SV22T1020659.Models.Sales.OrderStatusEnum.Shipping => "bg-warning text-dark",
                                            SV22T1020659.Models.Sales.OrderStatusEnum.Completed => "bg-success",
                                            SV22T1020659.Models.Sales.OrderStatusEnum.Cancelled => "bg-danger",
                                            SV22T1020659.Models.Sales.OrderStatusEnum.Rejected => "bg-secondary",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @bgClass px-3 py-2 rounded-pill">@item.StatusDescription</span>
                                </td>
                                <td class="text-end pe-4">
                                    <a href="~/Order/Details/@item.OrderID" class="btn btn-outline-primary btn-sm rounded-pill">
                                        Chi tiết
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (Model.PageCount > 1)
            {
                <div class="d-flex justify-content-center mt-4 pb-4">
                    <ul class="pagination">
                        @foreach (var p in Model.GetDisplayPages())
                        {
                            if (p.Page == 0)
                            {
                                <li class="page-item disabled"><span class="page-link border-0">...</span></li>
                            }
                            else
                            {
                                <li class="page-item @(p.Page == Model.Page ? "active" : "")">
                                    <a class="page-link border-0 shadow-sm mx-1 rounded" href="~/Order?page=@p.Page">@p.Page</a>
                                </li>
                            }
                        }
                    </ul>
                </div>
            }
        }
    </div>
</div>
