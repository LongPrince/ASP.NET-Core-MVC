@model SV22T1020659.Shop.Models.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-wrapper">
    <div class="card auth-card">
        <div class="card-header bg-white text-center py-4">
            <h2 class="mb-0 text-primary fw-bolder"><i class="fa-solid fa-circle-user mb-2 d-block fs-1"></i>Đăng nhập</h2>
            <p class="text-muted small mb-0 mt-2">Chào mừng trở lại! Vui lòng đăng nhập vào tài khoản của bạn.</p>
        </div>
        <div class="card-body p-4 p-md-5">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label fw-semibold text-secondary"></label>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-envelope"></i></span>
                        <input asp-for="Email" class="form-control border-start-0 ps-0" placeholder="name@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Password" class="form-label fw-semibold text-secondary mb-0"></label>
                        <a href="#" class="text-primary small text-decoration-none">Quên mật khẩu?</a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-light text-muted border-end-0"><i class="fa-solid fa-lock"></i></span>
                        <input asp-for="Password" class="form-control border-start-0 ps-0" placeholder="••••••••" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4 form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe">
                    <label class="form-check-label small text-muted" for="rememberMe">Ghi nhớ đăng nhập</label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fs-5 fw-semibold shadow-sm">Đăng nhập</button>
            </form>
        </div>
        <div class="card-footer bg-light text-center py-3 border-top-0">
            <span class="text-muted">Chưa có tài khoản?</span>
            <a asp-action="Register" class="text-primary fw-bold text-decoration-none ms-1">Đăng ký ngay</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
