@model SV22T1020659.Shop.Models.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row pt-4">
    <div class="col-md-3">
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-body p-4 text-center">
                <i class="fa-solid fa-circle-user text-muted" style="font-size: 80px;"></i>
                <h5 class="my-3">@User.Identity?.Name</h5>
            </div>
        </div>
        <div class="card mb-4 mb-lg-0 border-0 shadow-sm">
            <div class="card-body p-0">
                <ul class="nav flex-column profile-sidebar p-2">
                    <li class="nav-item">
                        <a class="nav-link text-body" asp-action="Profile">
                            <i class="fa-regular fa-id-badge me-2"></i> Thông tin cá nhân
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link active" asp-action="ChangePassword">
                            <i class="fa-solid fa-key me-2"></i> Đổi mật khẩu
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-body" href="#">
                            <i class="fa-solid fa-box-open me-2"></i> Lịch sử mua hàng
                        </a>
                    </li>
                    <li class="nav-item mt-2 border-top pt-2">
                        <a class="nav-link text-danger" asp-controller="Account" asp-action="Logout">
                            <i class="fa-solid fa-right-from-bracket me-2"></i> Đăng xuất
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="col-md-9">
        <div class="card mb-4 border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0 text-primary fw-bold"><i class="fa-solid fa-shield-halved me-2"></i>Bảo mật tài khoản</h5>
            </div>
            <div class="card-body p-4">
                @if (ViewBag.SuccessMessage != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fa-solid fa-check-circle me-2"></i> @ViewBag.SuccessMessage
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="ChangePassword" method="post" class="w-75">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="OldPassword" class="form-label fw-semibold"></label>
                        <input asp-for="OldPassword" class="form-control" />
                        <span asp-validation-for="OldPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label fw-semibold"></label>
                        <input asp-for="NewPassword" class="form-control" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" class="form-control" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div>
                        <button type="submit" class="btn btn-primary px-4">Xác nhận đổi mật khẩu</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
