@model SV22T1020659.Shop.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký tài khoản";
}

<div class="auth-wrapper">
    <div class="card auth-card">
        <div class="card-header bg-white text-center py-3">
            <h4 class="mb-0 text-primary fw-bold">Tạo tài khoản mới</h4>
            <p class="text-muted small mb-0 mt-1">Đăng ký để trải nghiệm mua sắm tuyệt vời</p>
        </div>
        <div class="card-body p-4">
            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="CustomerName" class="form-label fw-semibold"></label>
                    <input asp-for="CustomerName" class="form-control" placeholder="Nguyễn Văn A" />
                    <span asp-validation-for="CustomerName" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-semibold"></label>
                    <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-semibold"></label>
                    <input asp-for="Phone" class="form-control" placeholder="0901234567" />
                    <span asp-validation-for="Phone" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-semibold"></label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small d-block mt-1"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small d-block mt-1"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">Đăng ký ngay</button>
            </form>
        </div>
        <div class="card-footer bg-light text-center py-3">
            <span class="text-muted small">Đã có tài khoản?</span>
            <a asp-action="Login" class="text-primary fw-semibold text-decoration-none small ms-1">Đăng nhập</a>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
