<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Dang Long Store </title>
    <link rel="icon" type="image/png" sizes="16x16"  href="/favicon-16x16.png">
    <meta name="msapplication-TileColor" content="#ffffff">
    <meta name="theme-color" content="#ffffff">
    <!-- Google Fonts: Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/styles.css" asp-append-version="true" />
    <style>
        .payment-badge {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.45rem 0.85rem;
            border-radius: 999px;
            color: #fff;
            font-weight: 600;
            font-size: 0.95rem;
            line-height: 1;
        }
        .payment-badge.visa { background: #142688; }
        .payment-badge.mastercard { background: #ff5f00; }
        .payment-badge.momo { background: #ed1b24; }
        .payment-badge.zalopay { background: #0066ff; }
        .payment-badge i { width: 1.1rem; text-align: center; }
        .footer-social a:hover { color: #ffc107 !important; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light fixed-top">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="fa-solid fa-store me-2"></i>Dang Long Store
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Cart" asp-action="Index">
                                <i class="fa-solid fa-cart-shopping me-1"></i>Giỏ hàng 
                                <span class="badge bg-danger rounded-pill">@Context.Session.GetCart().Sum(m => m.Quantity)</span>
                            </a>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fa-regular fa-circle-user me-1"></i>@User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="navbarDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Hồ sơ cá nhân</a></li>
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">Đổi mật khẩu</a></li>
                                    <li><a class="dropdown-item" asp-controller="Order" asp-action="Index">Lịch sử đơn hàng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout">Đăng xuất</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Account" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div id="cart-toast" class="toast align-items-center text-white bg-success border-0 position-fixed top-0 start-50 translate-middle-x mt-4" role="alert" aria-live="assertive" aria-atomic="true" style="z-index: 9999; min-width: 250px;">
        <div class="d-flex">
            <div class="toast-body text-center w-100">
                <i class="fa-solid fa-circle-check me-2"></i>Đã thêm vào giỏ hàng
            </div>
        </div>
    </div>

    <main role="main" class="container" style="margin-top: 80px;">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white py-5">
        <div class="container">
            <div class="row gy-4">
                <div class="col-md-4">
                    <h5 class="mb-3">Dang Long Store</h5>
                    <p class="mb-2"><i class="fa-solid fa-phone me-2"></i>0778554647</p>
                    <p class="mb-2"><i class="fa-solid fa-location-dot me-2"></i>77 Nguyễn Huệ, Huế</p>
                    <p class="mb-2"><i class="fa-regular fa-envelope me-2"></i><a href="mailto:dangvanlong0702@gmail.com" class="text-white text-decoration-none">dangvanlong0702@gmail.com</a></p>
                    <p class="mb-0"><i class="fa-solid fa-mobile-screen-button me-2"></i>Zalo: 0778554647</p>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3">Liên kết nhanh</h5>
                    <ul class="list-unstyled">
                        <li><a class="text-white text-decoration-none" asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li><a class="text-white text-decoration-none" asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li><a class="text-white text-decoration-none" asp-controller="Cart" asp-action="Index">Giỏ hàng</a></li>
                        <li><a class="text-white text-decoration-none" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h5 class="mb-3">Kết nối với chúng tôi</h5>
                    <div class="d-flex align-items-center gap-3 footer-social">
                        <a href="https://www.facebook.com/angvanlong.671349/?locale=vi_VN" target="_blank" class="text-white fs-4"><i class="fa-brands fa-facebook"></i></a>
                        <a href="https://www.instagram.com/longprince6b/" target="_blank" class="text-white fs-4"><i class="fa-brands fa-instagram"></i></a>
                        <a href="https://github.com/LongPrince" target="_blank" class="text-white fs-4"><i class="fa-brands fa-github"></i></a>
                        <a href="https://zalo.me/0778554647" target="_blank" class="text-white fs-4"><i class="fa-solid fa-mobile-screen-button"></i></a>
                    </div>
                    <p class="mt-3 mb-2">Mở cửa: 8:00 - 21:00 mỗi ngày</p>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="payment-badge visa"><i class="fa-brands fa-cc-visa"></i>Visa</span>
                        <span class="payment-badge mastercard"><i class="fa-brands fa-cc-mastercard"></i>Mastercard</span>
                        <span class="payment-badge momo"><i class="fa-solid fa-mobile-screen-button"></i>Momo</span>
                        <span class="payment-badge zalopay"><i class="fa-solid fa-comment-dots"></i>ZaloPay</span>
                    </div>
                </div>
            </div>
            <div class="border-top border-secondary mt-4 pt-3 text-center">
                <small class="text-white-50">&copy; 2026 Dang Long Store. All rights reserved.</small>
            </div>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function addToCart(productId, quantity = 1) {
            $.ajax({
                url: '/Cart/AddToCart',
                type: 'POST',
                data: { id: productId, quantity: quantity },
                success: function(res) {
                    if (res.success) {
                        $('.navbar .badge').text(res.cartCount);
                        
                        // Hiển thị thông báo Toast
                        const toastElement = document.getElementById('cart-toast');
                        const toast = new bootstrap.Toast(toastElement, { delay: 3000 });
                        toast.show();
                    } else {
                        alert(res.message);
                    }
                },
                error: function() {
                    alert('Đã xảy ra lỗi khi thêm vào giỏ hàng.');
                }
            });
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
