@model PagedResult<Employee>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Ảnh</th>
                    <th>Họ tên</th>
                    <th>Ngày sinh</th>
                    <th>Điện thoại</th>
                    <th>Email</th>
                    <th>Địa chỉ</th>
                    <th class="text-center">Trạng thái</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/images/employees/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" 
                                     class="img-thumbnail" 
                                     style="width: 50px; height: 50px; object-fit: cover;" />
                            </td>
                            <td>@item.FullName</td>
                            <td>@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                            <td>@item.Phone</td>
                            <td>@item.Email</td>
                            <td>@item.Address</td>
                            <td class="text-center">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger ms-1" title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning ms-1" title="Đổi mật khẩu">
                                    <i class="bi bi-key"></i>
                                </a>
                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info ms-1" title="Cấp quyền">
                                    <i class="bi bi-shield-check"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="8" class="text-center">Không có dữ liệu phù hợp</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">«</a>
                </li>

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                        </li>
                    }
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">»</a>
                </li>
            </ul>
        </div>
    }
</div>
