@using SV22T1020659.Models.Catalog
@model Product
@{
    ViewBag.Title = "Xóa mặt hàng";
}

@section PageToolBar {
    @if (ViewBag.CanDelete == true)
    {
        <button type="submit" form="formDelete" class="btn btn-danger">
            <i class="bi bi-trash"></i> Xác nhận xóa
        </button>
    }
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0 text-danger">
            <i class="bi bi-box-seam me-2"></i> Xác nhận xóa mặt hàng
        </h5>
    </div>

    <div class="card-body">
        <form id="formDelete" method="post" action="~/Product/Delete/@Model.ProductID">
            @if (ViewBag.CanDelete == true)
            {
                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    Bạn có chắc chắn muốn xóa mặt hàng sau không?
                </div>
            }
            else
            {
                <div class="alert alert-danger">
                    <i class="bi bi-x-circle me-2"></i>
                    Không thể xóa mặt hàng này vì đang có dữ liệu liên quan (đơn hàng, kho...).
                </div>
            }

            <div class="row">
                <div class="col-md-2 text-center">
                    <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail"
                         style="width: 100%; max-width: 150px;"
                         alt="Ảnh mặt hàng" />
                </div>

                <div class="col-md-10">
                    <dl class="row mb-0">
                        <dt class="col-sm-3">Tên mặt hàng:</dt>
                        <dd class="col-sm-9">@Model.ProductName</dd>

                        <dt class="col-sm-3">Mô tả:</dt>
                        <dd class="col-sm-9">@(string.IsNullOrEmpty(Model.ProductDescription) ? "-" : Model.ProductDescription)</dd>

                        <dt class="col-sm-3">Đơn vị tính:</dt>
                        <dd class="col-sm-9">@Model.Unit</dd>

                        <dt class="col-sm-3">Giá bán:</dt>
                        <dd class="col-sm-9">@Model.Price.ToString("N0")</dd>

                        <dt class="col-sm-3">Trạng thái:</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Ngưng bán</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </form>
    </div>
</div>
