@using SV22T1020659.Models.Catalog
@model IEnumerable<ProductPhoto>
@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Photo/@ViewBag.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:50px" class="text-center">STT</th>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int sttPhoto = 1;
                        }
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-center align-middle">@(sttPhoto++)</td>
                                <td class="text-center align-middle">
                                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                         class="img-thumbnail"
                                         style="max-height:80px;" />
                                </td>
                                <td class="align-middle">@item.Description</td>
                                <td class="text-center align-middle">@item.DisplayOrder</td>
                                <td class="text-center align-middle">
                                    @if (!item.IsHidden)
                                    {
                                        <span class="badge bg-success">Hiện</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Ẩn</span>
                                    }
                                </td>
                                <td class="text-center text-nowrap align-middle">
                                    <a class="btn btn-sm btn-primary" href="~/Product/Photo/@item.ProductID?method=edit&photoId=@item.PhotoID">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-danger" href="~/Product/Photo/@item.ProductID?method=delete&photoId=@item.PhotoID" onclick="return confirm('Xóa ảnh này của mặt hàng?')">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>