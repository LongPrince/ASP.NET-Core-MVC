@using SV22T1020659.Models.Catalog
@model Product

@{
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" method="post" enctype="multipart/form-data" action="~/Product/SaveData">
                    <input type="hidden" asp-for="ProductID" />

                    <div class="mb-3">
                        <label class="form-label">Tên mặt hàng</label>
                        <input type="text" asp-for="ProductName"
                               class="form-control"
                               placeholder="Nhập tên mặt hàng" autofocus />
                        <span asp-validation-for="ProductName" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Mô tả</label>
                        <textarea class="form-control" asp-for="ProductDescription"
                                  rows="3"
                                  placeholder="Nhập mô tả"></textarea>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Loại hàng</label>
                            <select class="form-select" asp-for="CategoryID"
                                    asp-items="await SelectListHelper.Categories()">
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Nhà cung cấp</label>
                            <select class="form-select" asp-for="SupplierID"
                                    asp-items="await SelectListHelper.Suppliers()">
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Đơn vị tính</label>
                            <input type="text" asp-for="Unit"
                                   class="form-control"
                                   placeholder="Đơn vị tính (VD: cái, kg...)" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Giá</label>
                            <input type="text" asp-for="Price"
                                   class="form-control"
                                   placeholder="Giá bán" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label">Hình ảnh</label>
                        <div class="col-sm-10">
                            <input type="hidden" asp-for="Photo" />
                            <input type="file" name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)"
                                   data-img-preview="imgPreview" />
                            <div class="mt-2">
                                <img id="imgPreview"
                                     src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail"
                                     style="max-height: 200px;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-2 col-form-label">Trạng thái</label>
                        <div class="col-sm-10">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" asp-for="IsSelling"
                                       type="checkbox"
                                       id="IsSelling" />
                                <label class="form-check-label" for="IsSelling">
                                    Đang được bán
                                </label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    @* (Hiển thị danh sách ảnh và thuộc tính ở đây sau) *@
}