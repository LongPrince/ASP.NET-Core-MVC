@model PagedResult<Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Ảnh</th>
                    <th>Tên mặt hàng</th>
                    <th>Đơn vị tính</th>
                    <th>Giá</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center">
                                <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)" 
                                     class="img-thumbnail" 
                                     style="width: 50px; height: 50px; object-fit: cover;" />
                            </td>
                            <td>@item.ProductName</td>
                            <td>@item.Unit</td>
                            <td>@item.Price.ToString("N0")</td>
                            <td class="text-center">
                                <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Product/Delete/@item.ProductID" class="btn btn-sm btn-danger ms-1">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center">Không có dữ liệu phù hợp</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">«</a>
                </li>

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                        </li>
                    }
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">»</a>
                </li>
            </ul>
        </div>
    }
</div>
