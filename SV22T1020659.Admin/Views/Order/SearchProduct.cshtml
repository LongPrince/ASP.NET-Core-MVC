@model PagedResult<Product>
@{
    Layout = null;
}

<!-- Danh sách mặt hàng -->
@if (Model.DataItems.Any())
{
    foreach (var item in Model.DataItems)
    {
        <form method="post" action="~/Order/AddToCart" class="border rounded p-2 mb-2 cart-item-form">
            <input type="hidden" name="ProductID" value="@item.ProductID" />
            <input type="hidden" name="ProductName" value="@item.ProductName" />
            <input type="hidden" name="Unit" value="@item.Unit" />
            <input type="hidden" name="Photo" value="@item.Photo" />

            <strong>@item.ProductName</strong>

            <div class="row mt-2">
                <div class="col-4">
                    <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                         class="img-fluid border" style="max-height:100px" />
                </div>
                <div class="col-8">
                    <div class="row g-2">
                        <div class="col-7">
                            <label class="form-label mb-0">Giá</label>
                            <input class="form-control form-control-sm"
                                   name="SalePrice"
                                   value="@item.Price.ToString("N0")"
                                   readonly />
                        </div>
                        <div class="col-5">
                            <label class="form-label mb-0">SL</label>
                            <input type="number"
                                   name="Quantity"
                                   min="1"
                                   value="1"
                                   class="form-control form-control-sm" />
                        </div>
                    </div>

                    <button type="submit" class="btn btn-sm btn-primary mt-2 w-100">
                        <i class="bi bi-cart-plus"></i>
                        Thêm vào giỏ
                    </button>
                </div>
            </div>
        </form>
    }
}
else
{
    <div class="text-center text-muted py-4">
        Không tìm thấy mặt hàng nào
    </div>
}

<nav class="mt-2">
    <ul class="pagination pagination-sm justify-content-between mb-0">
        <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;" onclick="searchProduct(@(Model.Page - 1))">
                <i class="bi bi-chevron-left"></i>
            </a>
        </li>
        <li class="page-item disabled">
            <span class="page-link text-dark">Trang @Model.Page / @Model.PageCount</span>
        </li>
        <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
            <a class="page-link" href="javascript:;" onclick="searchProduct(@(Model.Page + 1))">
                <i class="bi bi-chevron-right"></i>
            </a>
        </li>
    </ul>
</nav>
