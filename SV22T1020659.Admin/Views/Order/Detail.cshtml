@using SV22T1020659.Models.Sales
@model OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var orderDetails = ViewBag.OrderDetails as List<OrderDetailViewInfo> ?? new List<OrderDetailViewInfo>();
    decimal totalOrderAmount = 0;
}

<div class="card card-primary card-outline">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i> Thông tin đơn hàng #@Model.OrderID
        </h5>
        
        @if (TempData["Message"] != null)
        {
            <div class="alert alert-warning border-0 ms-3 my-0 py-1 px-3">
                <i class="bi bi-exclamation-triangle me-1"></i> @TempData["Message"]
            </div>
        }

        <div class="ms-auto">
            @if (Model.Status == OrderStatusEnum.New)
            {
                <a href="~/Order/Accept/@Model.OrderID" class="btn btn-sm btn-primary" onclick="return confirm('Xác nhận duyệt chấp nhận đơn hàng này?')">
                    <i class="bi bi-check-circle"></i> Duyệt đơn hàng
                </a>
                <a href="~/Order/Reject/@Model.OrderID" class="btn btn-sm btn-warning ms-1" onclick="return confirm('Xác nhận từ chối đơn hàng này?')">
                    <i class="bi bi-x-circle"></i> Từ chối
                </a>
            }
            @if (Model.Status == OrderStatusEnum.Accepted)
            {
                <a href="~/Order/Shipping/@Model.OrderID" class="btn btn-sm btn-info" onclick="openModal(event, this)">
                    <i class="bi bi-truck"></i> Chuyển sang giao hàng
                </a>
            }
            @if (Model.Status == OrderStatusEnum.Shipping)
            {
                <a href="~/Order/Finish/@Model.OrderID" class="btn btn-sm btn-success" onclick="return confirm('Xác nhận đơn hàng đã hoàn tất thành công?')">
                    <i class="bi bi-flag"></i> Hoàn tất đơn hàng
                </a>
            }
            @if (Model.Status == OrderStatusEnum.New || Model.Status == OrderStatusEnum.Accepted)
            {
                <a href="~/Order/Cancel/@Model.OrderID" class="btn btn-sm btn-secondary ms-1" onclick="return confirm('Xác nhận hủy đơn hàng này?')">
                    <i class="bi bi-ban"></i> Hủy đơn hàng
                </a>
            }
            @if (Model.Status == OrderStatusEnum.Rejected || Model.Status == OrderStatusEnum.Cancelled)
            {
                <a href="~/Order/Delete/@Model.OrderID" class="btn btn-sm btn-danger ms-1" onclick="return confirm('Xác nhận xóa vĩnh viễn đơn hàng này?')">
                    <i class="bi bi-trash"></i> Xóa đơn hàng
                </a>
            }
            <a href="~/Order" class="btn btn-sm btn-secondary ms-1">
                <i class="bi bi-arrow-left"></i> Quay lại
            </a>
        </div>
    </div>

    <div class="card-body">
        <div class="row">
            <div class="col-md-4">
                <p><strong>Khách hàng:</strong> @Model.CustomerName</p>
                <p><strong>Người liên hệ:</strong> @Model.CustomerContactName</p>
                <p><strong>Điện thoại:</strong> @Model.CustomerPhone</p>
                <p><strong>Email:</strong> @Model.CustomerEmail</p>
                <p><strong>Địa chỉ khách hàng:</strong> @Model.CustomerAddress</p>
                <hr />
                <p><strong>Nơi giao hàng:</strong> @Model.DeliveryProvince</p>
                <p><strong>Địa chỉ giao:</strong> @Model.DeliveryAddress</p>
            </div>
            <div class="col-md-4">
                <p><strong>Ngày lập đơn hàng:</strong> @Model.OrderTime.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Nhân viên phụ trách:</strong> @Model.EmployeeName</p>
                <p><strong>Trạng thái:</strong> <span class="badge bg-primary">@Model.StatusDescription</span></p>
                <p><strong>Người giao hàng:</strong> @Model.ShipperName</p>
                <p><strong>Điện thoại:</strong> @Model.ShipperPhone</p>
            </div>
            <div class="col-md-4">
                <p><strong>Ngày duyệt đơn hàng:</strong> @Model.AcceptTime?.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Ngày giao hàng:</strong> @Model.ShippedTime?.ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Ngày hoàn tất:</strong> @Model.FinishedTime?.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <hr />

        <h6>Danh sách mặt hàng</h6>
        <table class="table table-bordered table-striped table-hover mt-3">
            <thead class="table-secondary">
                <tr>
                    <th style="width: 50px;">STT</th>
                    <th>Tên hàng</th>
                    <th>Đơn vị tính</th>
                    <th style="width: 100px;">Số lượng</th>
                    <th style="width: 150px;">Đơn giá</th>
                    <th style="width: 150px;">Thành tiền</th>
                    <th style="width: 80px;" class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (orderDetails.Count > 0)
                {
                    int stt = 1;
                    foreach (var item in orderDetails)
                    {
                        var amount = item.Quantity * item.SalePrice;
                        totalOrderAmount += amount;
                        <tr>
                            <td>@(stt++)</td>
                            <td>@item.ProductName</td>
                            <td>@item.Unit</td>
                            <td>@item.Quantity</td>
                            <td>@item.SalePrice.ToString("N0")</td>
                            <td>@amount.ToString("N0")</td>
                            <td class="text-center text-nowrap">
                                @if (Model.Status == OrderStatusEnum.New)
                                {
                                    <a href="~/Order/EditCartItem/@Model.OrderID?productID=@item.ProductID" class="btn btn-xs btn-primary btn-modal" onclick="openModal(event, this)">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Order/DeleteDetail/@Model.OrderID/@item.ProductID" class="btn btn-xs btn-danger ms-1" onclick="return confirm('Xác nhận xóa mặt hàng này khỏi đơn hàng?')" title="Xóa mặt hàng">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center">Đơn hàng chưa có mặt hàng nào.</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="5" class="text-end">Tổng cộng:</th>
                    <th class="text-danger">@totalOrderAmount.ToString("N0")</th>
                    <th></th>
                </tr>
            </tfoot>
        </table>
    </div>
</div>