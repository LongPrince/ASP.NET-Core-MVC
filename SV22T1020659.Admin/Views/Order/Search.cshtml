@model PagedResult<OrderViewInfo>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0">
            <thead class="table-secondary">
                <tr>
                    <th>Khách hàng</th>
                    <th>Ngày lập</th>
                    <th>Nhân viên</th>
                    <th>Người giao hàng</th>
                    <th>Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.DataItems.Any())
                {
                    foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td>
                                <strong>@item.CustomerName</strong> <br />
                                <small class="text-muted">@item.CustomerAddress</small>
                            </td>
                            <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@item.EmployeeName</td>
                            <td>@item.ShipperName</td>
                            <td>
                                @{
                                    string badgeClass = item.Status switch
                                    {
                                        OrderStatusEnum.New => "bg-info",
                                        OrderStatusEnum.Accepted => "bg-primary",
                                        OrderStatusEnum.Shipping => "bg-warning",
                                        OrderStatusEnum.Completed => "bg-success",
                                        OrderStatusEnum.Rejected => "bg-danger",
                                        OrderStatusEnum.Cancelled => "bg-secondary",
                                        _ => "bg-light"
                                    };
                                }
                                <span class="badge @badgeClass">@item.StatusDescription</span>
                            </td>
                            <td class="text-center">
                                <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-info" title="Xem chi tiết">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (item.Status == OrderStatusEnum.New || item.Status == OrderStatusEnum.Cancelled || item.Status == OrderStatusEnum.Rejected)
                                {
                                    <a href="~/Order/Delete/@item.OrderID" class="btn btn-sm btn-danger ms-1" title="Xóa">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center">Không có đơn hàng nào phù hợp với tìm kiếm</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page - 1))">«</a>
                </li>

                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.IsEllipsis)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else
                    {
                        <li class="page-item @(p.IsCurrent ? "active" : "")">
                            <a class="page-link" href="javascript:;"
                               onclick="paginationSearch(event, document.getElementById('formSearch'), @p.Page)">@p.Page</a>
                        </li>
                    }
                }

                <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                    <a class="page-link" href="javascript:;"
                       onclick="paginationSearch(event, document.getElementById('formSearch'), @(Model.Page + 1))">»</a>
                </li>
            </ul>
        </div>
    }
</div>
