@model SV22T1020659.Models.Sales.CartItem
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">
        Xóa mặt hàng khỏi đơn hàng
    </strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form id="formDeleteCartItem" action="~/Order/RemoveFromCart/@Model.ProductID" method="post">
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center">
            <i class="bi bi-info-circle me-2"></i>
            Bạn có muốn xóa mặt hàng <b>@Model.ProductName</b> này ra khỏi đơn hàng không?
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check"></i> Chấp nhận
        </button>
        <button type="button"
                class="btn btn-secondary"
                data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>

<script>
    $(document).ready(function () {
        $('#formDeleteCartItem').on('submit', function (e) {
            e.preventDefault();
            var form = $(this);
            $.ajax({
                url: form.attr('action'),
                type: form.attr('method'),
                data: form.serialize(),
                success: function (res) {
                    $('#dialogModal').modal('hide');
                    if (typeof showCart === "function") {
                        showCart();
                    } else if (typeof paginationSearch === "function") {
                         // Nếu ở trang danh sách đơn hàng thì reload
                         location.reload();
                    } else {
                        $('#showCart').html(res);
                    }
                }
            });
        });
    });
</script>