@using SV22T1020659.Models.Partner
@{
    Layout = null; // Thường dùng Modal
}

<div class="modal-dialog">
    <div class="modal-content">
        <form action="~/Order/Shipping/@ViewBag.OrderID" method="post" class="form-horizontal">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">Chuyển sang giao hàng</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">Chọn người giao hàng:</label>
                    <select class="form-select" name="shipperID" required>
                        @foreach (var shipper in await SelectListHelper.Shippers())
                        {
                            <option value="@shipper.Value">@shipper.Text</option>
                        }
                    </select>
                </div>
            </div>
            <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Xác nhận chuyển giao</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </form>
    </div>
</div>