@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-md-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearchProduct" action="~/Order/SearchProduct" method="get" class="mb-3">
                    <div class="input-group">
                        <input class="form-control"
                               name="searchValue" id="inputSearchProduct"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <!-- Vùng hiển thị danh sách mặt hàng tìm được -->
                <div id="searchProductResult">
                    @* (Được tải bằng AJAX) *@
                </div>
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-md-8">
        <div id="showCart">
            @* (Được tải bằng AJAX) *@
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Khi form tìm kiếm sản phẩm được submit
            $("#formSearchProduct").on("submit", function (e) {
                e.preventDefault();
                searchProduct(1);
            });

            // Tải dữ liệu ban đầu
            searchProduct(1);
            showCart();

            // Lắng nghe sự kiện submit form AddToCart (vì form này được tạo động bằng AJAX)
            $(document).on("submit", ".cart-item-form", function (e) {
                e.preventDefault();
                var form = $(this);
                var url = form.attr("action");
                var method = form.attr("method");
                var data = form.serialize();

                $.ajax({
                    url: url,
                    type: method,
                    data: data,
                    success: function (res) {
                        if (res !== "") {
                            $("#showCart").html(res);
                        }
                    }
                });
            });
        });

        // Hàm tìm kiếm mặt hàng
        function searchProduct(page) {
            var searchValue = $("#inputSearchProduct").val();
            var url = $("#formSearchProduct").attr("action");
            $.get(url, { searchValue: searchValue, page: page }, function (html) {
                $("#searchProductResult").html(html);
            });
        }

        // Hàm hiển thị giỏ hàng
        function showCart() {
            $.get("/Order/ShowCart", function (html) {
                $("#showCart").html(html);
            });
        }
    </script>
}
